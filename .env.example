# ============================================================================
# LAVACA - VARIABLES DE ENTORNO
# ============================================================================
# Copia este archivo a `.env.local` y completa los valores antes de levantar
# el servidor. Las claves marcadas como "obligatorias" deben existir para que
# la app arranque; el resto sólo se necesita cuando se va a activar el
# proveedor correspondiente en modo `production`.

# ============================================================================
# MODO DE PAGOS
# ============================================================================
# 'test'        → todas las pasarelas se simulan con MockProvider y los pagos
#                 se auto-confirman al instante (perfecto para desarrollo y QA).
# 'production'  → se usan los proveedores reales. Para cada pasarela activa
#                 debes setear sus credenciales.
NEXT_PUBLIC_PAYMENT_MODE=test

# ============================================================================
# APP (obligatorio)
# ============================================================================
NEXT_PUBLIC_URL=http://localhost:3000

# Secret para que un cron externo (Coolify Scheduled Task, GitHub Action,
# uptime-kuma, etc.) pueda invocar /api/cron/exchange-rate sin exponer
# la API de Binance a anónimos. Generá un valor aleatorio largo (32+ chars).
#   openssl rand -hex 32
CRON_SECRET=

# ============================================================================
# SUPABASE (obligatorio)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# STRIPE (opcional en modo test; obligatorio en producción para pagos con tarjeta)
# ============================================================================
# Crear en: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
# Webhook: https://dashboard.stripe.com/webhooks
#   Endpoint: {NEXT_PUBLIC_URL}/api/payments/stripe/webhook
#   Eventos:  checkout.session.completed, checkout.session.async_payment_failed,
#             payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================================================
# BINANCE PAY (opcional; obligatorio en producción para pagos con cripto)
# ============================================================================
# Crear en: https://merchant.binance.com → Developer → API Management
BINANCE_API_KEY=xxxxx
BINANCE_API_SECRET=xxxxx
BINANCE_PAY_CERT_SN=xxxxx
# Sandbox: https://bpay.binanceapi.com (default)  /  Producción: igual
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
# Webhook: configurar en el portal de Binance Pay apuntando a
#   {NEXT_PUBLIC_URL}/api/payments/binance/webhook

# ============================================================================
# CHINCHIN (Venezuela C2P) - STUB
# ============================================================================
# La integración real está stubeada. Cuando obtengas la cuenta de comercio,
# completa estos valores y cambia NEXT_PUBLIC_PAYMENT_MODE=production.
# La estructura del provider espera HMAC SHA-256 sobre `timestamp\nnonce\nbody\n`.
# Si ChinChin publica otra variante, ajustar `lib/payments/providers/chinchin-provider.ts`.
CHINCHIN_API_KEY=
CHINCHIN_API_SECRET=
CHINCHIN_MERCHANT_ID=
CHINCHIN_BASE_URL=https://api.chinchin.app
CHINCHIN_WEBHOOK_SECRET=
# Webhook a configurar en el portal de ChinChin:
#   {NEXT_PUBLIC_URL}/api/payments/chinchin/webhook

# ============================================================================
# PAYPAL (opcional; obligatorio en producción para PayPal)
# ============================================================================
# Crear en: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox:    https://api-m.sandbox.paypal.com (default si environment=sandbox)
# Producción: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
# ID del webhook creado en el dashboard de PayPal (para validar firmas).
# Webhook URL: {NEXT_PUBLIC_URL}/api/payments/paypal/webhook
# Eventos sugeridos: CHECKOUT.ORDER.APPROVED, CHECKOUT.ORDER.COMPLETED,
#   PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.DENIED,
#   PAYMENT.CAPTURE.REFUNDED, CHECKOUT.ORDER.VOIDED
PAYPAL_WEBHOOK_ID=

# ============================================================================
# ZELLE (manual)
# ============================================================================
# El admin aprueba a mano cada pago desde /admin/payments. Estos valores
# sólo se muestran al donante como instrucción de pago.
ZELLE_EMAIL=donations@lavaca.com.ve
ZELLE_PHONE=+58424123456

# ============================================================================
# PAGO MÓVIL (manual)
# ============================================================================
# Mientras no haya integración C2P bancaria, el donante reporta el pago y
# el admin lo aprueba desde /admin/payments. La configuración real (banco,
# teléfono, cédula, QR) se gestiona también desde /admin/payment-methods.
PAGOMOVIL_BANK_CODE=0134
PAGOMOVIL_PHONE=04241234567
PAGOMOVIL_CEDULA=V12345678
