# ============================================
# LAVACA - ENVIRONMENT VARIABLES
# ============================================

# ============================================
# PAYMENT SYSTEM
# ============================================
# Modo de pagos: 'test' o 'production'
# En modo test, todos los pagos se auto-confirman sin APIs reales
NEXT_PUBLIC_PAYMENT_MODE=test

# ============================================
# STRIPE
# ============================================
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================
# BINANCE
# ============================================
BINANCE_API_KEY=xxxxx
BINANCE_API_SECRET=xxxxx
BINANCE_PAY_CERT_SN=xxxxx
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com


# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# APP
# ============================================
NEXT_PUBLIC_URL=http://localhost:3000
